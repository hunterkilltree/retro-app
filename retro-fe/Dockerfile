# ─── Stage 1: Install dependencies ───────────────────────────────────────────
# Separate stage so npm install is cached unless package-lock.json changes.
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --frozen-lockfile

# ─── Stage 2: Build ───────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

# Copy node_modules from deps stage (avoids re-downloading)
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# BACKEND_URL is baked in at build time for server-side API route calls.
# Override with --build-arg BACKEND_URL=https://your-api.onrender.com
ARG BACKEND_URL=http://localhost:8080
ENV BACKEND_URL=$BACKEND_URL

RUN npm run build

# ─── Stage 3: Runtime ─────────────────────────────────────────────────────────
# next.config.ts sets output:"standalone", which copies only the files needed
# to run the server into .next/standalone — no node_modules folder required.
# Final image ≈ 150 MB vs ~1 GB for a naive copy.
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Non-root user
RUN addgroup -S nextjs && adduser -S nextjs -G nextjs
USER nextjs

# The standalone server + compiled static assets
COPY --from=builder --chown=nextjs:nextjs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nextjs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nextjs /app/public ./public

EXPOSE 3000

# server.js is generated by the standalone build
CMD ["node", "server.js"]
